{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iris Dataset Schema",
  "type": "object",
  "properties": {
    "sepal_length": { "type": "number", "minimum": 0 },
    "sepal_width": { "type": "number", "minimum": 0 },
    "petal_length": { "type": "number", "minimum": 0 },
    "petal_width": { "type": "number", "minimum": 0 },
    "species": { "type": "string", "enum": ["setosa", "versicolor", "virginica"] }
  },
  "required": ["sepal_length", "sepal_width", "petal_length", "petal_width", "species"]
}
